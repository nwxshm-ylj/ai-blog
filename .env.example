APP_NAME="AI Blog"
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/ai_blog

LOG_LEVEL=INFO
SECRET_KEY=change-me-for-local-development-only
SESSION_COOKIE_NAME=ai_blog_session
SESSION_MAX_AGE_SECONDS=1209600

# Local development only. Production must set a long, random SECRET_KEY.
